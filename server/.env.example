# ==============================================
# SERVER CONFIGURATION
# ==============================================

# Server port (default: 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ==============================================
# DATABASE (MongoDB)
# ==============================================

# Local development
MONGODB_URI=mongodb://localhost:27017/lich-su-so

# Production example (thay thế với connection string thật)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lich-su-so

# ==============================================
# JWT AUTHENTICATION
# ==============================================

# Secret key cho JWT (nên dài và phức tạp, ít nhất 32 ký tự)
# Generate online: https://randomkeygen.com/
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT expiration time (default: 7d)
JWT_EXPIRE=7d

# ==============================================
# CLOUDINARY (Image/File Storage)
# ==============================================

# Đăng ký miễn phí tại: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ==============================================
# ADMIN ACCOUNT (Tự động tạo khi chạy npm run create-admin)
# ==============================================

# Phone: 0123456789
# Password: admin123
# Role: teacher
# Email: admin@lichsuso.online
